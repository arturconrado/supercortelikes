# Runtime
NODE_ENV=development
APP_ENV=local
PORT=3001
LOG_LEVEL=info
BUILD_SHA=development
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=300
TERMS_VERSION=terms-2026-06
PRIVACY_VERSION=privacy-2026-06
NEXT_PUBLIC_TERMS_VERSION=terms-2026-06
NEXT_PUBLIC_PRIVACY_VERSION=privacy-2026-06

# PostgreSQL. Neon uses pooled DATABASE_URL and unpooled DIRECT_DATABASE_URL.
POSTGRES_DB=clipbr
POSTGRES_USER=clipbr_local
POSTGRES_PASSWORD=clipbr_local_9Tq4xV7mK2pR8sW6
POSTGRES_PORT=5432
DATABASE_URL=postgresql://clipbr_local:clipbr_local_9Tq4xV7mK2pR8sW6@localhost:5432/clipbr?schema=public
DIRECT_DATABASE_URL=postgresql://clipbr_local:clipbr_local_9Tq4xV7mK2pR8sW6@localhost:5432/clipbr?schema=public

# Authentication. Generate independent values of at least 32 characters.
JWT_SECRET=replace_this_with_at_least_32_random_characters_before_running
REFRESH_TOKEN_SECRET=replace_this_with_an_independent_32_character_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=30

# BullMQ / Render Key Value. Production must use maxmemory-policy=noeviction.
REDIS_PASSWORD=clipbr_local_5Hs8nR2qW7mK4vP9
REDIS_PORT=6379
REDIS_URL=redis://:clipbr_local_5Hs8nR2qW7mK4vP9@localhost:6379
QUEUE_PREFIX=clipbr-demo
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
PIPELINE_STAGE_CONCURRENCY_JSON={"ingestion":4,"transcription":1,"segmentation":3,"scoring":4,"clips":3,"captions":3,"rendering":1,"exports":3}
PIPELINE_EVENT_RETENTION_SECONDS=300
ANALYTICS_CACHE_TTL_SECONDS=30

# Private S3-compatible storage. Cloudflare R2 uses region auto and path style false.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=clipbr-videos
S3_ACCESS_KEY_ID=clipbr_local_admin
S3_SECRET_ACCESS_KEY=clipbr_local_7Zp9mQ4vN8xK2rT6wF3s
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Direct multipart upload
UPLOAD_MODE=direct
MAX_UPLOAD_SIZE_BYTES=5368709120
UPLOAD_PART_SIZE_BYTES=67108864
UPLOAD_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,video/webm,video/x-matroska,video/x-msvideo
UPLOAD_QUEUE_SIZE=2

# Bundled Node/Python worker
MEDIA_WORKER_URL=http://127.0.0.1:8090
MEDIA_WORKER_TOKEN=replace_this_with_an_internal_32_character_secret
MEDIA_WORKER_DATA_DIR=/data/pipelines
MEDIA_WORKER_TIMEOUT_MS=7200000
MEDIA_MAX_CONCURRENT_JOBS=2
MEDIA_HEAVY_CONCURRENT_JOBS=1
MEDIA_LIGHT_CONCURRENT_JOBS=4
FFMPEG_PRESET=veryfast
FFMPEG_CRF=22
FFMPEG_THREADS=2
FFMPEG_FILTER_THREADS=1
RENDER_MAX_HEIGHT=720
RENDER_MAX_SOURCE_SHORT_SIDE=2160
ALLOW_FULL_BATCH_RENDER=false
YTDLP_FRAGMENT_CONCURRENCY=4
ENABLE_AI=true
ENABLE_WHISPERX=true
ENABLE_OPENCV=true
ENABLE_MEDIAPIPE=true
ENABLE_YOLO=true
MEDIA_DIARIZATION_ENABLED=false
MEDIA_TRANSCRIPTION_BATCH_SIZE=1
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_TIMEOUT_SECONDS=45
YTDLP_COOKIES_FILE=
YTDLP_PROXY=
YTDLP_USER_AGENT=
WHISPERX_MODEL=tiny
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
HF_TOKEN=
HF_HOME=/data/models/huggingface
TORCH_HOME=/data/models/torch
XDG_CACHE_HOME=/data/models/cache
MPLCONFIGDIR=/data/models/matplotlib
YOLO_CONFIG_DIR=/data/models

# Optional integrations
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_FROM=noreply@picashorts.com
EMAIL_VERIFICATION_REQUIRED=false
TURNSTILE_REQUIRED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_BYPASS_TOKEN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=clipbr-api
OBSERVABILITY_ENABLED=true
MEDIA_WORKER_METRICS_ENABLED=true
PROMETHEUS_RETENTION=15d
LOKI_RETENTION=168h
GRAFANA_PUBLIC_URL=http://localhost:3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_this_with_a_strong_grafana_admin_password
GRAFANA_BASIC_AUTH_USER=admin
GRAFANA_BASIC_AUTH_PASSWORD_HASH=replace_this_with_caddy_hash_password_output

# Temporary aliases accepted during rollout
CORS_ORIGINS=http://localhost:3000
UPLOAD_MAX_BYTES=5368709120
S3_ACCESS_KEY=clipbr_local_admin
S3_SECRET_KEY=clipbr_local_7Zp9mQ4vN8xK2rT6wF3s
S3_PUBLIC_ENDPOINT=http://localhost:9000
MEDIA_WORKER_INTERNAL_TOKEN=

# Legacy production Compose aliases
PRODUCTION_DATABASE_URL=
PRODUCTION_DIRECT_DATABASE_URL=
PRODUCTION_REDIS_URL=
PRODUCTION_JWT_SECRET=
PRODUCTION_REFRESH_TOKEN_SECRET=
PRODUCTION_S3_ENDPOINT=
PRODUCTION_S3_PUBLIC_ENDPOINT=
PRODUCTION_S3_REGION=auto
PRODUCTION_S3_ACCESS_KEY=
PRODUCTION_S3_SECRET_KEY=
PRODUCTION_S3_BUCKET=
PRODUCTION_PUBLIC_APP_URL=
PRODUCTION_PUBLIC_API_URL=
PRODUCTION_CORS_ORIGINS=
PRODUCTION_MEDIA_WORKER_TOKEN=
