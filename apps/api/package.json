{
  "name": "@clipbr/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:dev": "nest start --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://validate:validate@localhost:5432/validate} prisma validate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1073.0",
    "@aws-sdk/lib-storage": "3.1073.0",
    "@aws-sdk/s3-request-presigner": "3.1073.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "11.0.0",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-fastify": "11.1.27",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@prisma/client": "6.19.3",
    "ajv": "8.18.0",
    "argon2": "0.44.0",
    "bullmq": "5.79.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "ioredis": "5.10.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "prisma": "6.19.3",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.27",
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "4.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
