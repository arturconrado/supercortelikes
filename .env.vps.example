# Copy to .env.production on the VPS and replace every CHANGE_ME value.
# Generate secrets with: openssl rand -base64 48

# Domains
APP_DOMAIN=DOMINIO.com
CADDY_EMAIL=admin@DOMINIO.com
PUBLIC_APP_URL=https://DOMINIO.com
PUBLIC_API_URL=https://api.DOMINIO.com
CORS_ORIGIN=https://DOMINIO.com
CORS_ORIGINS=https://DOMINIO.com
S3_PUBLIC_ENDPOINT=https://storage.DOMINIO.com
S3_CORS_ALLOWED_ORIGINS_JSON='["https://DOMINIO.com"]'

# VPS paths
VPS_PROVIDER=digitalocean
VPS_SIZE_PROFILE=budget
VPS_DATA_DIR=/srv/clipbr/data
VPS_BACKUP_DIR=/srv/clipbr/backups

# Runtime
NODE_ENV=production
APP_ENV=production
LOG_LEVEL=info
BUILD_SHA=vps-manual
RATE_LIMIT_MAX=300
TERMS_VERSION=terms-2026-06
PRIVACY_VERSION=privacy-2026-06
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=30

# PostgreSQL
POSTGRES_DB=clipbr
POSTGRES_USER=clipbr
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_LOCAL_PORT=55432

# Redis / BullMQ
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
QUEUE_PREFIX=clipbr-vps
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
PIPELINE_STAGE_CONCURRENCY_JSON={"ingestion":4,"transcription":2,"segmentation":3,"scoring":4,"clips":3,"captions":3,"rendering":2,"exports":3}
PIPELINE_EVENT_RETENTION_SECONDS=300
ANALYTICS_CACHE_TTL_SECONDS=30

# MinIO private S3-compatible storage
S3_REGION=us-east-1
S3_BUCKET=clipbr-videos
S3_ACCESS_KEY_ID=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_FORCE_PATH_STYLE=true

# Direct multipart upload
UPLOAD_MODE=direct
MAX_UPLOAD_SIZE_BYTES=5368709120
UPLOAD_PART_SIZE_BYTES=67108864
UPLOAD_QUEUE_SIZE=2
UPLOAD_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,video/x-matroska,video/x-msvideo

# Authentication / internal tokens
JWT_SECRET=CHANGE_ME_48_BYTE_JWT_SECRET
REFRESH_TOKEN_SECRET=CHANGE_ME_48_BYTE_REFRESH_SECRET
MEDIA_WORKER_TOKEN=CHANGE_ME_48_BYTE_MEDIA_WORKER_SECRET

# AI / media worker
MEDIA_WORKER_TIMEOUT_MS=7200000
MEDIA_MAX_CONCURRENT_JOBS=2
MEDIA_HEAVY_CONCURRENT_JOBS=2
MEDIA_LIGHT_CONCURRENT_JOBS=4
FFMPEG_PRESET=veryfast
FFMPEG_CRF=22
YTDLP_FRAGMENT_CONCURRENCY=4
ENABLE_AI=true
ENABLE_WHISPERX=true
ENABLE_OPENCV=true
ENABLE_MEDIAPIPE=true
ENABLE_YOLO=true
MEDIA_DIARIZATION_ENABLED=false
MEDIA_TRANSCRIPTION_BATCH_SIZE=1
LLM_PROVIDER=openrouter
LLM_API_KEY=CHANGE_ME_OPENROUTER_API_KEY
LLM_MODEL=openai/gpt-4o-mini
LLM_TIMEOUT_SECONDS=45
# Optional. Required in practice when YouTube blocks VPS datacenter IPs.
# Put a Netscape cookies.txt file on the VPS, for example:
# /srv/clipbr/data/media/cookies/youtube.txt -> /data/cookies/youtube.txt in the container.
YTDLP_COOKIES_FILE=
YTDLP_PROXY=
YTDLP_USER_AGENT=
WHISPERX_MODEL=tiny
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
HF_TOKEN=

# Commercial integrations — required for production launch
MERCADO_PAGO_ACCESS_TOKEN=CHANGE_ME_MERCADO_PAGO_ACCESS_TOKEN
MERCADO_PAGO_WEBHOOK_SECRET=CHANGE_ME_MERCADO_PAGO_WEBHOOK_SECRET
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
EMAIL_FROM=noreply@DOMINIO.com
EMAIL_VERIFICATION_REQUIRED=true
TURNSTILE_REQUIRED=true
TURNSTILE_SECRET_KEY=CHANGE_ME_TURNSTILE_SECRET_KEY
TURNSTILE_BYPASS_TOKEN=
ALLOW_TURNSTILE_BYPASS_IN_PRODUCTION=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGE_ME_TURNSTILE_SITE_KEY

# Observability, optional for first VPS deploy
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=clipbr-api

# Optional encrypted env backup
VPS_BACKUP_GPG_RECIPIENT=
