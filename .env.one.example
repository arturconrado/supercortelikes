# ClipBR local production-like all-in-one
# Copy to .env.one if you want to override defaults:
#   cp .env.one.example .env.one

ONE_WEB_PORT=3330
ONE_API_PORT=3331
ONE_STORAGE_PORT=3332
ONE_MINIO_CONSOLE_PORT=3333

POSTGRES_DB=clipbr
POSTGRES_USER=clipbr_local
POSTGRES_PASSWORD=clipbr_local_9Tq4xV7mK2pR8sW6
REDIS_PASSWORD=clipbr_local_5Hs8nR2qW7mK4vP9

JWT_SECRET=clipbr_one_local_jwt_secret_replace_48_chars_2026
REFRESH_TOKEN_SECRET=clipbr_one_local_refresh_secret_replace_48_chars_2026
MEDIA_WORKER_TOKEN=clipbr_one_media_token_replace_48_chars_2026

S3_BUCKET=clipbr-videos
S3_ACCESS_KEY_ID=clipbr_local_admin
S3_SECRET_ACCESS_KEY=clipbr_local_7Zp9mQ4vN8xK2rT6wF3s

LOG_LEVEL=info
HEARTBEAT_INTERVAL_SECONDS=10
COMPOSITION_V1_ENABLED=false
COMPOSITION_V1_ROLLOUT_PERCENT=100
MEDIA_ACCELERATOR=cpu

# Optional LLM scoring. Keep real keys only in .env.one, never in this example.
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_PROVIDER_SORT=latency
LLM_TIMEOUT_SECONDS=45
